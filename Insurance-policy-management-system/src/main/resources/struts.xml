<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN" "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
    <constant name="struts.enable.DynamicMethodInvocation" value="false" />
    <constant name="struts.devMode" value="true" />
    <constant name="struts.objectFactory" value="spring" />

    <package name="default" namespace="/" extends="struts-default, json-default">

        <interceptors>
            <interceptor name="authInterceptor" class="com.policymanagement.interceptor.AuthInterceptor"/>
            <interceptor-stack name="agentStack">
                <interceptor-ref name="defaultStack"/>
                <interceptor-ref name="authInterceptor">
                    <param name="requiredRole">AGENT</param>
                </interceptor-ref>
            </interceptor-stack>
            <interceptor-stack name="customerStack">
                <interceptor-ref name="defaultStack"/>
                <interceptor-ref name="authInterceptor">
                    <param name="requiredRole">CUSTOMER</param>
                </interceptor-ref>
            </interceptor-stack>
        </interceptors>

        <!-- LOGIN -->
        <action name="loginAction" class="loginAction" method="login">
            <result type="json" name="agent"><param name="root">jsonResponse</param></result>
            <result type="json" name="customer"><param name="root">jsonResponse</param></result>
            <result type="json" name="error"><param name="root">jsonResponse</param></result>
            <result type="json" name="input"><param name="root">jsonResponse</param></result>
        </action>

        <!-- LOGOUT -->
        <action name="logoutAction" class="loginAction" method="logout">
            <result name="success" type="redirect">/login.jsp</result>
        </action>

        <!-- REGISTRATION -->
        <action name="registerAction" class="registrationAction" method="register">
            <result name="success">/register-success.jsp</result>
            <result name="input">/register.jsp</result>
            <result name="error">/register.jsp</result>
        </action>

        <!-- AGENT DASHBOARD -->
        <action name="agentDashboard" class="policyAction" method="listPolicies">
            <interceptor-ref name="agentStack"/>
            <result name="success">/agentDashboard.jsp</result>
            <result name="unauthorized" type="redirect">/login.jsp</result>
        </action>

        <!-- POLICY FORM PAGE -->
        <action name="policyForm" class="policyAction" method="execute">
            <interceptor-ref name="agentStack"/>
            <result name="success">/policyForm.jsp</result>
            <result name="unauthorized" type="redirect">/login.jsp</result>
        </action>

        <!-- ADD POLICY -->
        <action name="addPolicy" class="policyAction" method="addPolicy">
            <interceptor-ref name="agentStack"/>
            <result name="success" type="redirect">agentDashboard</result>
            <result name="input">/policyForm.jsp</result>
            <result name="error">/policyForm.jsp</result>
            <result name="unauthorized" type="redirect">/login.jsp</result>
        </action>

        <!-- DELETE POLICY - JSON for AJAX -->
        <action name="deletePolicy" class="policyAction" method="deletePolicy">
            <interceptor-ref name="agentStack"/>
            <result type="json" name="success">
                <param name="root">jsonResponse</param>
            </result>
            <result type="json" name="error">
                <param name="root">jsonResponse</param>
            </result>
            <result name="unauthorized" type="redirect">/login.jsp</result>
        </action>

        <!-- LIST POLICIES - forwards to policies.jsp -->
        <action name="listPolicies" class="policyAction" method="listPolicies">
            <interceptor-ref name="agentStack"/>
            <result name="success">/policies.jsp</result>
            <result name="unauthorized" type="redirect">/login.jsp</result>
        </action>

        <!-- GET POLICIES JSON - called by jQuery AJAX inside policies.jsp -->
        <action name="getPoliciesJson" class="policyAction" method="listPolicies">
            <interceptor-ref name="agentStack"/>
            <result type="json" name="success">
                <param name="root">jsonResponse</param>
            </result>
            <result name="unauthorized" type="redirect">/login.jsp</result>
        </action>

        <!-- CUSTOMER DASHBOARD -->
        <action name="customerDashboard" class="policyAction" method="listPolicies">
            <interceptor-ref name="customerStack"/>
            <result name="success">/customerDashboard.jsp</result>
            <result name="unauthorized" type="redirect">/login.jsp</result>
        </action>

        <!-- BROWSE POLICIES -->
        <action name="browsePolicies" class="policyAction" method="listPolicies">
            <interceptor-ref name="customerStack"/>
            <result name="success">/browsePolicies.jsp</result>
            <result name="unauthorized" type="redirect">/login.jsp</result>
        </action>

        <!-- MY POLICIES -->
        <action name="myPolicies" class="policyAction" method="listPolicies">
            <interceptor-ref name="customerStack"/>
            <result name="success">/myPolicies.jsp</result>
            <result name="unauthorized" type="redirect">/login.jsp</result>
        </action>

    </package>
</struts>
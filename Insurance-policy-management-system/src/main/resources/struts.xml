<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "https://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
    <constant name="struts.objectFactory" value="spring"/>
    <constant name="struts.devMode"       value="true"/>

    <package name="default" namespace="/" extends="struts-default,json-default">

        <interceptors>
            <interceptor name="authInterceptor"
                class="com.policymanagement.interceptor.AuthInterceptor"/>
            <interceptor-stack name="authStack">
                <interceptor-ref name="defaultStack"/>
                <interceptor-ref name="authInterceptor"/>
            </interceptor-stack>
        </interceptors>

        <global-results>
            <result name="unauthorized">/error.jsp</result>
        </global-results>

        <!-- PUBLIC -->
      <action name="login" class="loginAction" method="login">
        <result name="agent">/agentDashboard.jsp</result>
        <result name="customer">/customerDashboard.jsp</result>
        <result name="error">/login.jsp</result>
    </action>

        <action name="logout" class="loginAction" method="logout">
            <result name="success" type="redirect">/login.jsp</result>
            <interceptor-ref name="defaultStack"/>
        </action>

        <action name="register" class="registrationAction" method="register">
            <result name="success">/register-success.jsp</result>
            <result name="input">/register.jsp</result>
            <result name="error">/register.jsp</result>
            <interceptor-ref name="defaultStack"/>
        </action>

        <!-- AGENT -->
        <action name="agentDashboard" class="policyAction" method="listPolicies">
            <result name="success">/agentDashboard.jsp</result>
            <interceptor-ref name="authStack"/>
        </action>

        <action name="addPolicy" class="policyAction" method="addPolicy">
            <result name="success" type="redirect">/agentDashboard.action</result>
            <result name="input">/policyForm.jsp</result>
            <result name="error">/policyForm.jsp</result>
            <interceptor-ref name="authStack"/>
        </action>

        <action name="listAllPolicies" class="policyAction" method="listPolicies">
            <result name="success">/policies.jsp</result>
            <interceptor-ref name="authStack"/>
        </action>

        <action name="deletePolicy" class="policyAction" method="deletePolicy">
            <result name="success" type="redirect">/agentDashboard.action</result>
            <result name="error">/agentDashboard.jsp</result>
            <interceptor-ref name="authStack"/>
        </action>

        <!-- CUSTOMER -->
        <action name="customerDashboard" class="policyAction" method="listPolicies">
            <result name="success">/customerDashboard.jsp</result>
            <interceptor-ref name="authStack"/>
        </action>

        <action name="browsePolicies" class="policyAction" method="listPolicies">
            <result name="success">/browsePolicies.jsp</result>
            <interceptor-ref name="authStack"/>
        </action>

        <action name="purchasePolicy" class="customerPolicyAction" method="purchasePolicy">
            <result name="success" type="redirect">/myPolicies.action</result>
            <result name="error">/browsePolicies.jsp</result>
            <result name="input">/browsePolicies.jsp</result>
            <interceptor-ref name="authStack"/>
        </action>

        <action name="myPolicies" class="customerPolicyAction" method="viewMyPolicies">
            <result name="success">/myPolicies.jsp</result>
            <result name="error">/error.jsp</result>
            <interceptor-ref name="authStack"/>
        </action>

    </package>
</struts>